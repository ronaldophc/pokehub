APP_NAME=PokeHub
APP_ENV=production
APP_KEY=                          # gerar com: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://SEU_DOMINIO

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=pokehub
DB_USERNAME=pokehub
DB_PASSWORD=SENHA_FORTE_AQUI
DB_ROOT_PASSWORD=SENHA_ROOT_FORTE_AQUI

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=pokehub
REVERB_APP_KEY=CHAVE_REVERB_AQUI      # string aleatória, ex: openssl rand -hex 16
REVERB_APP_SECRET=SEGREDO_REVERB_AQUI # string aleatória, ex: openssl rand -hex 32
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=SEU_DOMINIO
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@SEU_DOMINIO
MAIL_FROM_NAME=PokeHub
